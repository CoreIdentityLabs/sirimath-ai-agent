# ============================================================
# Telegram BYOK Personal Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ─── Telegram Bot Configuration ────────────────────────────
# Required: Your Telegram bot token from BotFather
# https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Bot polling mode: "polling" (local dev) or "webhook" (production server)
# Default: polling
TELEGRAM_MODE=polling

# Required only when TELEGRAM_MODE=webhook — full HTTPS URL for Telegram to call
# Example: https://yourserver.com/webhook
# TELEGRAM_WEBHOOK_URL=https://yourserver.com/webhook

# Optional: Comma-separated Telegram user IDs allowed to use the bot (access control)
# Leave unset to allow all users (open mode)
# Find your user ID via @userinfobot on Telegram
# ALLOWED_TELEGRAM_USER_IDS=123456789,987654321

# ─── LLM Provider (BYOK — Bring Your Own Key) ──────────────
# Supported providers: openai, anthropic, google, azure, groq, mistral, ollama
# Default: openai
MODEL_PROVIDER=openai

# Model identifier for the selected provider (default: gpt-4o-mini)
MODEL_ID=gpt-4o-mini

# ─── OpenAI ────────────────────────────────────────────────
# Required when MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Example: Switch to GPT-4o
# MODEL_PROVIDER=openai
# MODEL_ID=gpt-4o
# OPENAI_API_KEY=sk-...

# ─── Anthropic ─────────────────────────────────────────────
# Required when MODEL_PROVIDER=anthropic
# MODEL_PROVIDER=anthropic
# MODEL_ID=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Gemini ─────────────────────────────────────────
# Required when MODEL_PROVIDER=google
# MODEL_PROVIDER=google
# MODEL_ID=gemini-2.0-flash-exp
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# ─── Azure AI Foundry ──────────────────────────────────────
# Required when MODEL_PROVIDER=azure
# MODEL_PROVIDER=azure
# MODEL_ID=gpt-4o            # Azure deployment name
# AZURE_API_KEY=your_azure_api_key
# AZURE_RESOURCE_NAME=your-resource-name  # e.g. my-openai-resource (without .openai.azure.com)

# ─── Groq ──────────────────────────────────────────────────
# Required when MODEL_PROVIDER=groq
# MODEL_PROVIDER=groq
# MODEL_ID=llama-3.3-70b-versatile
# GROQ_API_KEY=gsk_...

# ─── Mistral ───────────────────────────────────────────────
# Required when MODEL_PROVIDER=mistral
# MODEL_PROVIDER=mistral
# MODEL_ID=mistral-large-latest
# MISTRAL_API_KEY=...

# ─── Ollama (Local Models) ─────────────────────────────────
# No API key required. Ollama must be running locally.
# MODEL_PROVIDER=ollama
# MODEL_ID=llama3.2
# Optional: custom Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ─── VoltOps Observability (Optional) ──────────────────────
# Optional: VoltOps telemetry keys for observability dashboard
# https://app.voltops.ai
# Leave empty to disable telemetry (no data sent)
VOLTAGENT_PUBLIC_KEY=
VOLTAGENT_SECRET_KEY=

# ─── Web Search (Optional) ──────────────────────────────────
# Set ONE of the following to enable the webSearch tool.
# Without a key the webSearch tool is registered but returns a "not configured" message.

# Brave Search API (https://api.search.brave.com)
# BRAVE_SEARCH_API_KEY=your-brave-search-api-key

# Tavily Search API — designed for AI agents (https://tavily.com)
# TAVILY_API_KEY=your-tavily-api-key

# ─── Voice Provider / STT & TTS (Optional) ─────────────────
# Set VOICE_PROVIDER to enable voice message support in Telegram.
# Supported: "openai" or "azure". Leave unset to disable voice (text-only mode).
# VOICE_PROVIDER=openai

# STT model (speech-to-text). Default: whisper-1
# STT_MODEL=whisper-1

# TTS model (text-to-speech). Default: tts-1
# TTS_MODEL=tts-1

# TTS voice. Default: alloy
# Options: alloy, echo, fable, onyx, nova, shimmer, ash, coral, sage
# TTS_VOICE=alloy

# ─── Azure OpenAI Voice (when VOICE_PROVIDER=azure) ────────
# Reuses AZURE_API_KEY and AZURE_RESOURCE_NAME from the LLM section above.
# IMPORTANT: Azure requires explicit deployment names — OpenAI model names
# like "whisper-1" are NOT valid. You must create deployments in Azure AI Foundry
# and use those deployment names here.
# STT_MODEL and TTS_MODEL are REQUIRED when VOICE_PROVIDER=azure.
# AZURE_API_KEY=your_azure_api_key
# AZURE_RESOURCE_NAME=your-resource-name  # e.g. my-openai-resource (without .openai.azure.com)
# STT_MODEL=your-whisper-deployment-name  # Required for Azure: your Whisper deployment name
# TTS_MODEL=your-tts-deployment-name      # Required for Azure: your TTS deployment name
